APP_NAME=QueryMind v2
APP_ENV=dev

# true = deterministic local mock adapter; false = live Gemini + Elasticsearch adapter
MOCK_MODE=true

ELASTIC_ENDPOINT=https://localhost:9200
ELASTIC_API_KEY=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

QUERY_TIMEOUT_MS=30000
MAX_RESULTS_LIMIT=1000
REQUEST_ID_HEADER=X-Request-ID
LOG_LEVEL=INFO
LIVE_MAX_RETRIES=2
LIVE_BACKOFF_BASE_MS=300
